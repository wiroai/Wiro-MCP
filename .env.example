# Required: Your Wiro project API key
WIRO_API_KEY=your-api-key

# Optional: Your Wiro project API secret (required for signature auth, omit for API Key Only auth)
WIRO_API_SECRET=your-api-secret

# Optional: Override the API base URL (default: https://api.wiro.ai/v1)
# WIRO_API_BASE_URL=https://api.wiro.ai/v1
